# Time-Off Microservice Configuration

## Database
DATABASE_URL=sqlite:./data/timeoff.db
DATABASE_SYNCHRONIZE=false
DATABASE_LOGGING=false

## HCM Integration
HCM_BASE_URL=http://localhost:3001/hcm
HCM_API_KEY=test-api-key-dev
HCM_TIMEOUT_MS=5000

## Cache Configuration
CACHE_TTL_MINUTES=30
CACHE_MAX_SIZE=10000

## Sync Configuration
BATCH_SYNC_INTERVAL_HOURS=6
DRIFT_DETECTION_ENABLED=true
DRIFT_CHECK_INTERVAL_MINUTES=60

## Retry Configuration
MAX_RETRIES=3
RETRY_INITIAL_DELAY_MS=500
RETRY_MAX_DELAY_MS=5000

## Circuit Breaker Configuration
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_MS=120000

## Application
TAKE_OFF_PORT=3000
APP_PORT=3000
APP_NAME=TimeOffMicroservice
NODE_ENV=development
LOG_LEVEL=info
